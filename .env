# ══════════════════════════════════════════════════════════════════════════════
# REDES SOCIALES – completar cuando conectes cada cuenta
# ══════════════════════════════════════════════════════════════════════════════

# ── Instagram Business (Meta Graph API – GRATIS) ─────────────────────────────
# Obtener en: https://developers.facebook.com → Tu App → WhatsApp/Instagram → Access Token
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=

# ── WhatsApp Cloud API (GRATIS hasta 1000 conversaciones/mes) ────────────────
# Mismo proyecto de Meta que Instagram – sin costo adicional
# Obtener en: https://developers.facebook.com → Tu App → WhatsApp → Configuración
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# ── TikTok (semi-automático – no requiere aprobación) ───────────────────────
# El contenido se envía al WhatsApp del admin para publicar con 1 toque
# Si quieres API completa: https://developers.tiktok.com
TIKTOK_ACCESS_TOKEN=
